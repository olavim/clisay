// Allocation- and GC-heavy: instantiate a short-lived object every iteration so
// the collector runs repeatedly. Exercises type instantiation, the GC
// threshold/marking, and per-call allocation.
type Box {
    pub v;
    init(v) {
        this.v = v;
    }
}

say i = 0;
say sum = 0;
while i < 300000 {
    say b = Box(i);
    sum = sum + b.v;
    i = i + 1;
}
