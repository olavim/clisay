type A {
    pub fn a() {
        print("a");
    }

    pub fn current() {
        print("a");
    }
}

type B : A {
    pub fn b() {
        print("b");
    }

    pub fn current() {
        print("b");
    }
}

say obj = B();
obj.a(); // expect: a
obj.b(); // expect: b
obj.current(); // expect: b