// `if`/`else` and bare `{ … }` are statements: they run their branches for
// effect and never produce a value. (Value-producing blocks/ifs were removed.)

// if-statement, no else: then runs / is skipped.
say mut a = 0;
if (true) { a = 1; }
print(a); // expect: 1

say mut b = 0;
if (false) { b = 1; }
print(b); // expect: 0

// if-statement with else.
say mut c = 0;
if (false) { c = 1; } else { c = 2; }
print(c); // expect: 2

// else-if chain.
say mut d = 0;
if (false) { d = 1; } else if (true) { d = 2; } else { d = 3; }
print(d); // expect: 2

// Bare block statement with side effects.
say mut e = 0;
{ e = 5; }
print(e); // expect: 5
