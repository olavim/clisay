// `.` is the method surface; `[]` is keyed data. They never collide, even when a
// data key shares a method's name.
say d = {};
d["has"] = "data-at-has";   // store DATA at key "has"
d["size"] = 99;             // store DATA at key "size"

// data via []
print(d["has"]); // expect: data-at-has
// method via . -> key "has" is present
print(d.containsKey("has")); // expect: true
// data via []
print(d["size"]); // expect: 99
// method via . -> 2 entries
print(d.size()); // expect: 2

// a stored function is called via [] (data); a method is called via .
d["fn"] = () => "stored-fn";
print(d["fn"]()); // expect: stored-fn
print(d.containsKey("fn")); // expect: true
