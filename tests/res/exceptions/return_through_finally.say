// `return` inside try/catch must run the enclosing `finally` before returning.

// return from the try body
fn fromTry()! {
    try {
        return "try";
    } finally {
        print("finally1");
    }
}
// expect: finally1
print(fromTry()); // expect: try

// return from the catch body
fn fromCatch()! {
    try {
        throw "boom";
    } catch (e) {
        return "catch";
    } finally {
        print("finally2");
    }
}
// expect: finally2
print(fromCatch()); // expect: catch

// a `return` inside the finally overrides the try body's return
fn returnInFinally()! {
    try {
        return "try";
    } finally {
        return "finally";
    }
}
print(returnInFinally()); // expect: finally

// sibling returns in the same try body each run the finally
fn siblingReturns(c)! {
    try {
        if (c) { return "a"; }
        return "b";
    } finally {
        print("cleanup");
    }
}
print(siblingReturns(true));
// expect: cleanup
// expect: a
print(siblingReturns(false));
// expect: cleanup
// expect: b
