// Bind a method to a local without keeping any other reference to the
// instance, then force collection. The bound method's `target` is the only
// thing keeping the instance alive, so ObjBoundMethod::mark must walk it.
//
// After collection we allocate fresh instances of the same shape so that, if
// the target were wrongly freed, its slot would be reused and the final call
// would print garbage instead of "hi".

type Foo {
    val;
    init(v) {
        this.val = v;
    }
    fn bar() {
        print(this.val);
    }
}

say m = Foo("h" + "i").bar;
gcCollect();

say a = Foo("xx" + "yy");
say b = Foo("zz" + "ww");
say c = Foo("pa" + "dd");

m(); // expect: hi
