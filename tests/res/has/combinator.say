// `&` ANDs two surfaces on one value; `|` tries alternatives. Each operand carries its keyword.
trait Polygon { req sides; }
trait Logger { req log; }
type Shape { pub sides; init() { this.sides = 3; } }

say d = { sides: 3, log: 1 };
print(d has Polygon & has Logger); // expect: true
print(d has Polygon & has Logger & has { extra: _ }); // expect: false
print(d has { sides: _ } & { log: _ }); // expect: true

say e = { sides: 3 };
print(e has Polygon & has Logger); // expect: false
print(e has Polygon | has Logger); // expect: true

// `&`/`|` mix structural and nominal freely
say s = Shape();
print(s has Polygon & is Shape); // expect: true
print(d has Polygon & is Shape); // expect: false
print(d has { missing: _ } | has Polygon); // expect: true
