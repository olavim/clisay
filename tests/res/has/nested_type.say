// A value-position type test carries its keyword: `is T` is nominal, `has T` is structural.
type Shape { pub a; init() { this.a = 1; } }

say s = Shape();
say d = { nested: s };
print(d has { nested: is Shape }); // expect: true
print(d has { nested: has Shape }); // expect: true

say e = { nested: { a: 1 } };
print(e has { nested: is Shape }); // expect: false
print(e has { nested: has Shape }); // expect: true
