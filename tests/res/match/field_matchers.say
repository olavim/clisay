fn classify(v?) {
    match v {
        { k: 1 | 2 | 3 } => print("small"),
        { k: _ } => print("big"),
        _ => print("no-k"),
    }
}
classify({ k: 2 }); // expect: small
classify({ k: 9 }); // expect: big
classify({ j: 0 }); // expect: no-k
classify(5); // expect: no-k

fn deep(v?) {
    if v ~ { a: { b: [first, ..rest] } } { print(first); print(rest.length()); } else { print("no"); }
}
deep({ a: { b: [10, 20, 30] } }); // expect: 10
// expect: 2
deep({ a: { b: 5 } }); // expect: no
deep({ a: 1 }); // expect: no
