// `is`/`has` with a destructuring shape, and a nominal outer with a structural inner.
type Point { pub x; pub y; init(a, b) { this.x = a; this.y = b; } }

say p = Point(3, 4);
if p ~ is Point { x, y } {
    print(x); // expect: 3
    print(y); // expect: 4
}

say e = { payload: { dx: 9 } };
if e ~ { payload: { dx } } {
    print(dx); // expect: 9
}

say b = p ~ is Point { x: 3 };
print(b); // expect: true
