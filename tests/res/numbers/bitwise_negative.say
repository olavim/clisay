// Bitwise operators cast f64 operands to i64, operate, then cast back, so they
// work on negative values via two's complement.
print(-1 & 255); // expect: 255
print(~0); // expect: -1
print(~5); // expect: -6
print(1 << 30); // expect: 1073741824
print(-8 >> 1); // expect: -4
print(-1 | 0); // expect: -1
