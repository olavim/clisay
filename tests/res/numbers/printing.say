// Numbers are f64; integral values print without a decimal point, and division
// keeps full f64 precision.
print(4 / 2); // expect: 2
print(1 / 2); // expect: 0.5
print(10 / 3); // expect: 3.3333333333333335
print(0.0); // expect: 0
print(0 - 0); // expect: 0
print(1000000 * 1000000); // expect: 1000000000000
print(123456789012); // expect: 123456789012
