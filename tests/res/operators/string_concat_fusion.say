// Regression: `const + local` string concatenation must keep the const operand first. The
// `const + local` fusion previously reused the `local + const` opcode, reversing the result.
fn f(m)! { return "L=" + m; }   // const + local
fn g(m)! { return m + "=R"; }   // local + const
print(f("X")); // expect: L=X
print(g("X")); // expect: X=R

say prefix = "[";
say name = "core";
print(prefix + name); // expect: [core
