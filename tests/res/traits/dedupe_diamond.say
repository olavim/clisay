// A behavior trait reached via two paths is folded once.
trait Base { pub fn id()! { return 7; } }
trait Left  with Base { pub fn l()! { return 1; } }
trait Right with Base { pub fn r()! { return 2; } }

type T with Left, Right { init() {} }

say t = T();
print(t.id()); // expect: 7
print(t.l()); // expect: 1
print(t.r()); // expect: 2
