// Implicit `this`: inside a trait body, bare references to the trait's own members resolve to
// `this.<member>` — including its private fields and methods (resolved per-trait by the resolver),
// and a local/param shadows a same-named private member.
trait Counter {
    n = 0;                                  // private field
    fn step() { return 1; }                 // private method
    pub fn bump() { this.n = n + step(); return n; }   // bare `n`, bare `step()`
    pub fn shadow(n) { return n + step(); }            // param `n` shadows the private field
}
trait Other {
    n = 100;                                // a different private `n` — must not collide
    pub fn other() { return n; }
}
type Widget with Counter, Other { init() {} }
say w = Widget();
print(w.bump());      // expect: 1
print(w.bump());      // expect: 2
print(w.shadow(40));  // 40 + 1
// expect: 41
print(w.other());     // expect: 100
