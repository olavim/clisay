// Construction order (§6): field defaults apply before the init body runs, so a
// stateful trait's init can read a defaulted field — including one from a `with`-owned
// defaulted-only trait.
trait Base { pub factor = 10; } // defaulted-only, no init

trait Scaled with Base {
    pub scaled;
    init(n) { this.scaled = n * this.factor; } // reads Base's default `factor`
}

type Thing with Scaled {
    pub label = "x" + "y"; // a default that is a (non-literal) expression
    init(n) { Scaled.init(n); } // Base is not orchestrated (no init)
}

say t = Thing(3);
print(t.factor);  // expect: 10
print(t.scaled);  // expect: 30
print(t.label);   // expect: xy
