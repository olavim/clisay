// Per-trait init. Parameterized inits must be orchestrated explicitly (to pass args);
// parameterless inits run automatically when omitted — calling them is allowed, not
// required. Nested: Player owns Movement which owns Position.
trait Clock {
    pub time;
    init() { this.time = 0; }                            // parameterless
    pub fn tick() { this.time = this.time + 1; }
}
trait Counter {
    pub count;
    init() { this.count = 0; }                           // parameterless
    pub fn inc() { this.count = this.count + 1; }
}
trait Position {
    pub x; pub y;
    init(x, y) { this.x = x; this.y = y; }               // parameterized
    pub fn moveBy(dx, dy) { this.x = this.x + dx; this.y = this.y + dy; }
}
trait Movement with Position {
    pub speed;
    init(speed, x, y) {
        Position.init(x, y);                             // parameterized -> explicit
        this.speed = speed;
    }
}
type Player with Movement, Clock, Counter {
    pub name;
    init(name, speed) {
        Movement.init(speed, 0, 0);                      // parameterized -> explicit
        Clock.init();                                    // parameterless -> may call explicitly
        // Counter.init() omitted -> runs automatically
        this.name = name;
    }
}

say p = Player("hero", 5);
print(p.x);     // expect: 0
print(p.speed); // expect: 5
print(p.name);  // expect: hero
print(p.time);  // expect: 0
print(p.count); // expect: 0
p.moveBy(3, 4);
print(p.x);     // expect: 3
print(p.y);     // expect: 4
p.tick();
print(p.time);  // expect: 1
p.inc();
print(p.count); // expect: 1
