trait Greet { pub fn hi()! { return "hi"; } }
trait Loud with Greet { pub fn yell()! { return "YO"; } }
trait Other { pub fn ping()! { return 0; } }

type Service with Loud { init() {} }

// A type that structurally has Greet's `hi` but does not `with`-provide it.
type Lookalike {
    pub fn hi()! { return "hi"; }
    init() {}
}

say s = Service();
print(s is Service); // expect: true
print(s is Loud);    // expect: true
print(s is Greet);   // expect: true
print(s is Other);   // expect: false

// Non-instance left operands never error, they are simply not `T`.
print(null is Greet); // expect: false
print(5 is Greet);    // expect: false
say d = { "k": 1 };
print(d is Greet);    // expect: false

// Provision is nominal: a structural method match is not `is`.
say look = Lookalike();
print(look is Greet); // expect: false
print(look is Lookalike); // expect: true
