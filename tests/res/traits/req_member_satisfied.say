// A trait may `req` a bare member (state) the host provides, and use `this.<member>` (read+write).
trait Counter {
    req count;
    pub fn inc() { this.count = this.count + 1; }
    pub fn get() { return this.count; }
}
type Widget with Counter {
    pub count = 0;   // the host holds the state the trait requires
    init() {}
}

say w = Widget();
w.inc();
w.inc();
print(w.get());  // expect: 2
print(w.count);  // expect: 2
